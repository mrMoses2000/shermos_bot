# ============================================================
# Shermos Bot — Environment Variables
# ============================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32    (for WEBHOOK_SECRET)
#   openssl rand -base64 24 (for POSTGRES_PASSWORD)
# ============================================================

# --- Telegram Client Bot ---
# Get from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=replace_me
# Random hex string for webhook verification (openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=replace_me_client_secret

# --- Telegram Manager Bot ---
# Create a SECOND bot in @BotFather for manager notifications
MANAGER_BOT_TOKEN=replace_me
MANAGER_WEBHOOK_SECRET=replace_me_manager_secret
# Comma-separated Telegram user IDs of managers (get from @userinfobot)
MANAGER_CHAT_IDS=

# --- Webhook Server ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=88
WEBHOOK_PUBLIC_URL=https://3.79.24.73:88
WEBHOOK_PATH_CLIENT=/webhook/client
WEBHOOK_PATH_MANAGER=/webhook/manager
SSL_CERT_PATH=certs/webhook.pem
SSL_KEY_PATH=certs/webhook.key

# --- Renders ---
RENDERS_DIR=data/renders

# --- Gallery (real-work photos attached by managers) ---
GALLERY_DIR=data/gallery
GALLERY_PHOTO_MAX_BYTES=8388608

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shermos_bot
POSTGRES_USER=shermos
POSTGRES_PASSWORD=change_me

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Gemini CLI (LLM) ---
# Auth: OAuth (run `gemini` interactively once on server to complete OAuth flow)
# Credentials are stored in ~/.gemini/ — no API key needed.
# Model to use (auto-discovered by Gemini CLI from .env)
GEMINI_MODEL=gemini-3-flash-preview
# CLI invocation settings
LLM_CLI_COMMAND=gemini
# Empty = stdin pipe mode (recommended, no prompt size limit)
# Set to "-p" to pass prompt as CLI argument instead
LLM_CLI_FLAGS=
MAX_LLM_CONCURRENCY=2
LLM_TIMEOUT_SECONDS=90

# --- Timezone ---
TIMEZONE=Asia/Bishkek

# --- Bot Behavior ---
BOT_LANGUAGE=ru
SEND_TYPING_INDICATOR=true
MAX_CONTEXT_MESSAGES=20
RENDER_CACHE_TTL_SECONDS=3600

# --- Mini App (set after building mini-app/) ---
MINI_APP_URL=

# --- AssemblyAI (voice transcription) ---
# Leave empty to disable voice transcription. Clients will get a polite
# message asking them to retype their question as text.
ASSEMBLYAI_API_KEY=
# Language code for transcription: ru | en | de | auto (automatic detection)
TRANSCRIPTION_LANGUAGE=ru
# Max wall-clock time to wait for transcription to complete (seconds)
TRANSCRIPTION_TIMEOUT_SECONDS=180

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
